generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
}

enum HilfsverbType {
  HABEN
  SEIN
}

enum GameType {
  FILL_BLANK
  MATCH_PAIRS
  TRANSLATE
  AUDIO
}

// Korisnički nalog — studenti i admini
model User {
  id               String        @id @default(uuid())
  email            String        @unique
  name             String
  surname          String
  displayName      String        @map("display_name")
  role             UserRole      @default(STUDENT)
  verificationCode String?       @map("verification_code")
  isVerified       Boolean       @default(false) @map("is_verified")
  avatarUrl        String?       @map("avatar_url")
  language         String        @default("srb")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  stats            Stats[]
  savedVerbs       SavedVerb[]
  sessions         ExerciseSession[]
  streak           Streak?
  settings         UserSetting[]

  @@map("users")
}

// Nemački glagol sa svim prezentskim konjugacijama i perfektom
// Tagovi u rečenicama: <verbId,lice> npr. <abc123,ich>
model Verb {
  id            String        @id @default(uuid())
  infinitiv     String        @unique
  // Prezent — svih 6 lica
  ich           String
  du            String
  erSieEs       String        @map("er_sie_es")
  wir           String
  ihr           String
  sieSie        String        @map("sie_Sie")
  // Perfekt
  perfekt       String
  hilfsverb     HilfsverbType
  // Klasifikacija
  lesson        Int           // Poglavlje 1–13
  difficulty    Int           @default(1) // 1=lako, 2=srednje, 3=teško
  // Prevodi
  translation   String?       // srpski
  translationHu String?       @map("translation_hu")
  translationEn String?       @map("translation_en")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  sentences     Sentence[]
  stats         Stats[]
  savedBy       SavedVerb[]

  @@map("verbs")
}

// Rečenica sa tagovima <verbId,lice> za vežbu "Popuni prazninu"
// Primer: "Ich <abc,ich> Student." → korisnik unosi "bin"
model Sentence {
  id            String   @id @default(uuid())
  verbId        String   @map("verb_id")
  verb          Verb     @relation(fields: [verbId], references: [id], onDelete: Cascade)
  template      String   // rečenica sa tagovima
  translation   String   // srpski prevod
  translationHu String?  @map("translation_hu")
  translationEn String?  @map("translation_en")
  difficulty    Int      @default(1)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("sentences")
}

// Statistike korisnika po glagolu
model Stats {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verbId        String    @map("verb_id")
  verb          Verb      @relation(fields: [verbId], references: [id], onDelete: Cascade)
  correctCount  Int       @default(0) @map("correct_count")
  wrongCount    Int       @default(0) @map("wrong_count")
  totalPoints   Int       @default(0) @map("total_points")
  totalTimeMs   BigInt    @default(0) @map("total_time_ms")
  lastPracticed DateTime? @map("last_practiced")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([userId, verbId])
  @@map("stats")
}

// Sačuvani glagoli (bookmark za ponavljanje)
model SavedVerb {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verbId    String   @map("verb_id")
  verb      Verb     @relation(fields: [verbId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, verbId])
  @@map("saved_verbs")
}

// Sesija vežbanja (za leaderboard, analitiku i bodovanje)
model ExerciseSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType     GameType @map("game_type")
  lesson       Int      // Lekcija 1–13
  score        Int      @default(0)
  maxScore     Int      @default(0) @map("max_score")
  correctCount Int      @default(0) @map("correct_count")
  wrongCount   Int      @default(0) @map("wrong_count")
  durationMs   BigInt   @default(0) @map("duration_ms")
  completedAt  DateTime @default(now()) @map("completed_at")

  @@map("exercise_sessions")
}

// Day streak praćenje uzastopnog korišćenja
model Streak {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastActiveDate DateTime? @map("last_active_date")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("streaks")
}

// Korisnička podešavanja (jezik interfejsa, notifikacije, itd.)
model UserSetting {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, key])
  @@map("user_settings")
}
